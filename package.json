{
  "name": "cursouls",
  "displayName": "Cursouls",
  "description": "Turn your Cursor into tiny pixel characters that live in a cozy cafe with your AI agents, reacting, assisting, and keeping you company while you work.",
  "version": "0.1.5",
  "publisher": "wunderlabs",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/wunderlabs-dev/cursouls"
  },
  "homepage": "https://cursouls.xyz",
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#fdf6e3",
    "theme": "light"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorCafe.refresh",
        "title": "Cursor Cafe: Refresh"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cursorCafe",
          "title": "Cursor Cafe",
          "icon": "media/cafe.svg"
        }
      ]
    },
    "views": {
      "cursorCafe": [
        {
          "id": "cursorCafe.sidebar",
          "name": "Cafe Sidebar",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "cursorCafe.refresh",
          "when": "view == cursorCafe.sidebar",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "build": "npm run compile",
    "assets:copy": "mkdir -p ./dist/static/fonts ./dist/static/images && cp ./src/static/fonts/* ./dist/static/fonts/ && cp ./src/static/images/* ./dist/static/images/",
    "css:build": "tailwindcss -i ./src/static/css/tailwind.css -o ./dist/webview.css --minify",
    "css:watch": "tailwindcss -i ./src/static/css/tailwind.css -o ./dist/webview.css --watch",
    "compile": "npm run css:build && npm run assets:copy && node esbuild.mjs",
    "watch": "npm run css:watch & node esbuild.mjs --watch",
    "format": "biome format --write ./src ./test",
    "lint": "biome check ./src ./test && eslint .",
    "lint:biome": "biome check ./src ./test",
    "lint:eslint": "eslint .",
    "typecheck": "npm run typecheck:extension && npm run typecheck:webview",
    "typecheck:extension": "tsc -p tsconfig.extension.json --noEmit",
    "typecheck:webview": "tsc -p tsconfig.webview.json --noEmit",
    "test": "vitest run",
    "check": "biome check ./src ./test && eslint . && npm run typecheck && npm run test",
    "release": "npm version patch --no-git-tag-version && npx @vscode/vsce package --no-dependencies",
    "release:minor": "npm version minor --no-git-tag-version && npx @vscode/vsce package --no-dependencies",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome format --write",
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@eslint/js": "^9.39.0",
    "@tailwindcss/cli": "^4.1.13",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^6.1.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@agentprobe/core": "^0.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lodash": "^4.17.23",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-fast-marquee": "^1.6.5",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  }
}
