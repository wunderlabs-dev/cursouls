{
  "name": "cursor-cafe",
  "displayName": "Cursor Cafe",
  "description": "A minimal VS Code extension with a custom activity bar sidebar.",
  "version": "0.0.1",
  "publisher": "cursor-cafe",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorCafe.refresh",
        "title": "Cursor Cafe: Refresh"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cursorCafe",
          "title": "Cursor Cafe",
          "icon": "media/cafe.svg"
        }
      ]
    },
    "views": {
      "cursorCafe": [
        {
          "id": "cursorCafe.sidebar",
          "name": "Cafe Sidebar",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "cursorCafe.refresh",
          "when": "view == cursorCafe.sidebar",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "build": "npm run compile",
    "css:build": "tailwindcss -c tailwind.config.cjs -i ./src/static/css/tailwind.css -o ./dist/webview.css --minify",
    "compile": "npm run css:build && node esbuild.mjs",
    "watch": "npm run css:build && node esbuild.mjs --watch",
    "format": "biome format --write ./src ./test",
    "lint": "biome lint ./src ./test",
    "check": "biome check ./src ./test",
    "typecheck": "npm run typecheck:extension && npm run typecheck:webview",
    "typecheck:extension": "tsc -p tsconfig.extension.json --noEmit",
    "typecheck:webview": "tsc -p tsconfig.webview.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/lodash.truncate": "^4.4.9",
    "@types/lodash.uniq": "^4.5.9",
    "@types/lodash.upperfirst": "^4.3.9",
    "@types/lodash.words": "^4.2.9",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.90.0",
    "@tailwindcss/cli": "^4.1.13",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "lodash.truncate": "^4.4.2",
    "lodash.uniq": "^4.5.0",
    "lodash.upperfirst": "^4.3.1",
    "lodash.words": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  }
}
