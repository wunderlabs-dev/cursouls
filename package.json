{
  "name": "cursor-cafe",
  "displayName": "Cursor Cafe",
  "description": "A minimal VS Code extension with a custom activity bar sidebar.",
  "version": "0.0.1",
  "publisher": "cursor-cafe",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorCafe.refresh",
        "title": "Cursor Cafe: Refresh"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cursorCafe",
          "title": "Cursor Cafe",
          "icon": "media/cafe.svg"
        }
      ]
    },
    "views": {
      "cursorCafe": [
        {
          "id": "cursorCafe.sidebar",
          "name": "Cafe Sidebar",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "cursorCafe.refresh",
          "when": "view == cursorCafe.sidebar",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Cursor Cafe",
      "properties": {
        "cursorCafe.refreshMs": {
          "type": "integer",
          "default": 250,
          "minimum": 100,
          "maximum": 10000,
          "description": "How often to poll for transcript changes (milliseconds)."
        },
        "cursorCafe.seatCount": {
          "type": "integer",
          "default": 20,
          "minimum": 1,
          "maximum": 100,
          "description": "Number of seats (tables) visible in the cafe scene."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "build": "npm run compile",
    "css:build": "tailwindcss -c tailwind.config.cjs -i ./src/static/css/tailwind.css -o ./dist/webview.css --minify",
    "compile": "npm run css:build && node esbuild.mjs",
    "watch": "npm run css:build && node esbuild.mjs --watch",
    "format": "biome format --write ./src ./test",
    "lint": "biome check ./src ./test && eslint .",
    "lint:biome": "biome check ./src ./test",
    "lint:eslint": "eslint .",
    "typecheck": "npm run typecheck:extension && npm run typecheck:webview",
    "typecheck:extension": "tsc -p tsconfig.extension.json --noEmit",
    "typecheck:webview": "tsc -p tsconfig.webview.json --noEmit",
    "test": "vitest run",
    "check": "biome check ./src ./test && eslint . && npm run typecheck && npm run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.1.13",
    "@types/lodash.truncate": "^4.4.9",
    "@types/lodash.upperfirst": "^4.3.9",
    "@types/lodash.words": "^4.2.9",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.0",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^6.1.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@agentprobe/core": "^0.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lodash.truncate": "^4.4.2",
    "lodash.upperfirst": "^4.3.1",
    "lodash.words": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  }
}
