{
  "compilerOptions": {
    "target": "ES2020",
    "strict": true,
    "noEmit": true,
    "sourceMap": true,
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@ext/*": [
        "src/extension/*"
      ],
      "@web/*": [
        "src/webview/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ],
      "@test/*": [
        "test/*"
      ]
    },
    "skipLibCheck": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.extension.json"
    },
    {
      "path": "./tsconfig.webview.json"
    },
    {
      "path": "./tsconfig.test.json"
    }
  ]
}
